    "This will discard your custom prompt and restore the default template." : {
      "comment" : "An alert message that appears when the user confirms resetting a custom prompt to its default value.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies verwirft Ihren benutzerdefinierten Prompt und stellt die Standardvorlage wieder her."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto descartará su prompt personalizado y restaurará la plantilla predeterminada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela annulera votre invite personnalisée et restaurera le modèle par défaut."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カスタムプロンプトは破棄され、デフォルトのテンプレートに戻ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사용자 지정 프롬프트가 삭제되고 기본 템플릿이 복원됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso descartará seu prompt personalizado e restaurará o modelo padrão."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将丢弃您的自定义提示词并恢复为默认模板。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將丟棄您的自訂提示詞並恢復為預設範本。"
          }
        }
      }
    },
    "This will permanently delete all your OKR data. This action cannot be undone." : {
      "comment" : "A message displayed when the user confirms they want to clear all their OKR data.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
