    "Unix Domain Socket transport provides lower latency than HTTP. Ideal for local tools like Claude Code." : {
      "comment" : "A description of the Unix Domain Socket configuration section in the MCP settings view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der UNIX-Domain-Socket-Transport bietet eine geringere Latenz als HTTP. Ideal für lokale Werkzeuge wie Claude Code."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El transporte de socket de dominio UNIX proporciona una menor latencia que HTTP. Ideal para herramientas locales como Claude Code."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le transport par socket du domaine UNIX offre une plus faible latence que HTTP. Idéal pour les outils locaux comme Claude Code."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unix ドメイン ソケット トランスポートは HTTP よりも低レイテンシです。Claude Code などのローカル ツールに最適です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unix 도메인 소켓 전송은 HTTP보다 낮은 대기 시간을 제공합니다. Claude Code와 같은 로컬 도구에 이상적입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O transporte com Socket de Domínio Unix oferece menor latência do que o HTTP. Ideal para ferramentas locais como o Claude Code."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unix域套接字传输提供比HTTP更低的延迟。非常适合像Claude Code这样的本地工具。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unix 網域通訊端傳輸提供比 HTTP 更低的延遲。非常適合像 Claude Code 這樣的本地工具。"
          }
        }
      }
    },
